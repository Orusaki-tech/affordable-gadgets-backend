# Generated by Ansible - do not edit by hand; override via group_vars or vault
DJANGO_ENV=production
DEBUG=False
DJANGO_SETTINGS_MODULE=store.settings_production

# Database (local PostgreSQL on same VM)
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@127.0.0.1:5432/{{ db_name }}
DB_HOST=127.0.0.1
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_PORT=5432

# Django
SECRET_KEY={{ secret_key }}
ALLOWED_HOSTS={{ allowed_hosts }}
PORT=8000

# CORS and frontend
CORS_ALLOWED_ORIGINS={{ cors_allowed_origins }}
FRONTEND_BASE_URL={{ frontend_base_url }}
CSRF_TRUSTED_ORIGINS={{ csrf_trusted_origins | default(allowed_hosts) }}

# Cloudinary (set in group_vars or vault)
CLOUDINARY_CLOUD_NAME={{ cloudinary_cloud_name | default('') }}
CLOUDINARY_API_KEY={{ cloudinary_api_key | default('') }}
CLOUDINARY_API_SECRET={{ cloudinary_api_secret | default('') }}

# Pesapal (set in group_vars or vault)
PESAPAL_CONSUMER_KEY={{ pesapal_consumer_key | default('') }}
PESAPAL_CONSUMER_SECRET={{ pesapal_consumer_secret | default('') }}
PESAPAL_ENVIRONMENT={{ pesapal_environment | default('sandbox') }}
PESAPAL_CALLBACK_URL={{ pesapal_callback_url | default('') }}
PESAPAL_IPN_URL={{ pesapal_ipn_url | default('') }}

# Optional: email, Twilio, etc. (add as needed in group_vars)
SILKY_ENABLED=false
RUN_MIGRATIONS_ON_STARTUP=0
